# ===== クライアント（ブラウザに公開。秘密ではない） =====
# これらは lib/firebase/client.ts に既定値として埋め込み済みです。
# 別のFirebaseプロジェクトに切り替えたい場合のみ、ここで上書きできます（通常は未設定でOK）。
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# ===== サーバー専用（必須・絶対に NEXT_PUBLIC_ を付けない / 公開しない） =====
# Firebase コンソール → ⚙️設定 → プロジェクトの設定 → 「サービス アカウント」タブ
#  → 「新しい秘密鍵を生成」でダウンロードした JSON から転記する。
FIREBASE_PROJECT_ID=miyasyo-idpass
FIREBASE_CLIENT_EMAIL=
# private_key は改行を \n のままにして、全体をダブルクォートで囲む
FIREBASE_PRIVATE_KEY=""

# ===== 管理ページ（必須） =====
# 管理ページ /admin のパスワード
ADMIN_PASSWORD=444325
# 管理セッションCookieの署名鍵（32文字以上のランダム文字列を設定）
ADMIN_SESSION_SECRET=
