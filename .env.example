# ===== クライアント（ブラウザに公開される。秘密ではない） =====
# Firebase コンソール → プロジェクト設定 → 全般 → アプリ(Web) の構成からコピー
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# 任意
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# ===== サーバー専用（絶対に NEXT_PUBLIC_ を付けない） =====
# Firebase コンソール → プロジェクト設定 → サービスアカウント → 新しい秘密鍵を生成 した JSON から
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# private_key は改行を \n のままにして、全体をダブルクォートで囲む
FIREBASE_PRIVATE_KEY=""

# ===== 管理ページ =====
# 管理ページ /admin のパスワード
ADMIN_PASSWORD=444325
# 管理セッションCookieの署名鍵（32バイト以上のランダム文字列を設定）
ADMIN_SESSION_SECRET=
