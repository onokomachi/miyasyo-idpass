rules_version = '2';

// みやしょうPASS — クライアントからの直接アクセスは全面禁止。
// すべての読み書きはサーバー（Next.js API + Firebase Admin SDK）経由で行う。
// Admin SDK はこのルールをバイパスするため、児童データは外部から読めない。
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
